<div class="container">
  <div class="row">
    <div class="col-md-6">
      <h2>Form Ubah Data Contact</h2>

        <% if (typeof errors != "undefined") { %>
            <div class="alert alert-danger" role="alert">
                <ul>
                    <% errors.forEach(error => { %>
                        <li>
                            <%= error.msg %>
                        </li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <!-- kita pakai post karena bukan pakai api, jika pakai api maka langsung tulis put -->
      <form method="post" action="/contact/update">
           <!-- dalam proses ubah ada hal yang harus kita lakukan pada saat di kirim dia tidak mengirim data nama ,nohp, email saja
             kita akan mengirim juga data nama sebagai input hiden yang tida terlihat, karena jika tidak mengirim data hiden, pada saat 
             kalian ingin merubah nama misal iqbal menjadi iqbale, nanti kita tidak punya akses ke data lamanya padahal nama lamanya itu yang kita butuhin
             kalo email dan nohp itu tidak masalah tidak usah dikirim hidennnya-->
        <!-- penulisan hidennya bebas dimana aja -->
        <!-- <input type="hidden" name="oldNama" value="<= contact.nama%>"> -->
        <input type="hidden" name="oldNama" value="<%= (contact.oldNama) ? contact.oldNama : contact.nama%>">
        <!-- untuk input kita cek lagi karena jika cuma gitu aja maka nanti old namanya itu semisal nama iqbal, di pencet 2x maka akan tetap terkirim ini masalahnya -->
         <!-- kita akan pakai ternary atau operator or -->
        <div class="mb-3">
 
          <label for="nama" class="form-label">Nama</label>
          <!-- ingat atribute name disini dari input, dan nama adalah nama dari contact yang kita isikan-->
          <input
            type="text"
            class="form-control"
            id="nama"
            name="nama"
            required value="<%= contact.nama %>"
          />
        </div>
        <div class="mb-3">
          <label for="nohp" class="form-label">No Hp</label>
          <!-- ingat atribute name disini dari input, dan nama adalah nama dari contact yang kita isikan-->
          <input
            type="text"
            class="form-control"
            id="nohp"
            name="nohp"
            required
            value="<%= contact.nohp %>"
          />
        </div>
        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <!-- ingat atribute name disini dari input, dan nama adalah nama dari contact yang kita isikan-->
          <input
            type="email"
            class="form-control"
            id="email"
            name="email"
            required
            value="<%= contact.email %>"
          />
        </div>
        <button type="submit" class="btn btn-primary">
          Ubah Data Contact
        </button>
      </form>
    </div>
  </div>
</div>
